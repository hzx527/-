</div>

<!-- 模态框弹窗（统一展示故事和媒体）-->
<div id="storyModal" class="modal">
    <div class="modal-card">
        <div class="modal-media" id="modalMedia">
            <!-- 动态填充图片或视频占位符 -->
        </div>
        <div class="modal-content">
            <h3 id="modalTitle">花圃共建故事</h3>
            <div class="modal-story" id="modalStory">
                居民李阿姨带领孩子们一起播种了这片花圃，每一株都是邻里间的情谊。
            </div>
            <div class="modal-tag" id="modalExtra">👥 志愿者：12人 · 共建时间：2025年春</div>
            <button class="close-btn" id="closeModalBtn">关闭 ✨</button>
        </div>
    </div>
</div>

<script>
    // 定义每个热区对应的故事内容（文本+媒体资源，目前媒体展示示意图片，未来可换成AI生成的短视频）
    // 因为用户后续会使用可灵等工具转换视频，这里预留结构，目前使用示例图片（unsplash占位或者社区图片模拟）
    // 同时为了展现“视频”替代方案，其中一个故事可以使用视频占位符示意；其他故事用静态图示意。
    const storiesDB = {
        flowerbed: {
            title: "🌻 童心花圃 · 彩虹接力",
            story: "这块花圃原本是杂草丛生的转角，2024年春天，15位社区小志愿者和园艺师王爷爷一同翻土、育苗、设计种植带。如今这里有金鸡菊、鼠尾草和百日草，四季交替绽放。居民说这是「会微笑的花圃」。",
            mediaType: "image",
            mediaSrc: "https://picsum.photos/id/144/800/500",   // 免费示例图片，展示花园实感 (可替换为真实照片)
            extraTag: "👧🏻 小小志愿者12人 | 累计服务32小时 | 2024春"
        },
        adopt: {
            title: "🏷️ 认养牌 · 陈奶奶的月季园",
            story: "75岁的陈奶奶主动认养了这块月季区，每周三清晨都能看到她修剪枝条的身影。她说「花草就像老朋友，互相惦记」。认养牌上写着：爱心浇灌，芬芳共享。",
            mediaType: "image",
            mediaSrc: "https://picsum.photos/id/152/800/500",   // 花朵近景
            extraTag: "❤️ 认养人：陈秀英 & 睦邻小组 | 2024年至今"
        },
        bench: {
            title: "🪑 邻里聊天椅 · 记忆长椅",
            story: "这把长椅由木工爱好者老张和三家邻居共同翻新制作，木材来自社区旧改留下的木料。如今是大家歇脚、聊聊植物生长的角落。上面刻着「一起慢慢变老，一起慢慢变好」。",
            mediaType: "videoPlaceholder",  // 演示视频占位 后续可替换 AI 短视频
            mediaSrc: "",   // 占位显示提示
            extraTag: "🪚 老张木工班 & 7户邻居 | 2024.10 落成"
        },
        herb: {
            title: "🌿 螺旋香草园 · 疗愈之角",
            story: "按照朴门理念设计的螺旋香草园，种植了迷迭香、薄荷、百里香。社区爱好食疗的志愿者们定期举办「闻香下午茶」，用新鲜香草泡茶，分享种植喜悦。",
            mediaType: "image",
            mediaSrc: "https://picsum.photos/id/45/800/500",
            extraTag: "🌱 朴门工作坊 | 2025.03 完成 | 疗愈志愿者: 小梅医生"
        }
    };

    // 额外视频占位的构造内容 (符合不写代码也能参与，预留AI视频替换)
    // 为长椅故事生成自定义占位（示意未来加入可灵 / Runway 短视频）
    // 在媒体区域显示带有说明的占位块，表示可以替换成视频

    // 获取DOM元素
    const modal = document.getElementById('storyModal');
    const modalMediaDiv = document.getElementById('modalMedia');
    const modalTitle = document.getElementById('modalTitle');
    const modalStory = document.getElementById('modalStory');
    const modalExtra = document.getElementById('modalExtra');
    const closeBtn = document.getElementById('closeModalBtn');

    // 点击地图区域时, 通过area的data-story属性查找对应内容
    const areas = document.querySelectorAll('map area');
    
    function openStory(storyKey) {
        const data = storiesDB[storyKey];
        if (!data) return;
        
        // 设置标题、故事、额外标记
        modalTitle.innerText = data.title;
        modalStory.innerText = data.story;
        modalExtra.innerText = data.extraTag;
        
        // 根据 mediaType 渲染媒体区域 (图片/视频占位)
        modalMediaDiv.innerHTML = ''; // 清空
        if (data.mediaType === 'image') {
            const img = document.createElement('img');
            img.src = data.mediaSrc;
            img.alt = data.title;
            img.style.width = '100%';
            img.style.display = 'block';
            modalMediaDiv.appendChild(img);
        } 
        else if (data.mediaType === 'videoPlaceholder') {
            // 构建一个“AI视频示例占位”，未来可以替换成 .mp4 视频文件，现在指出可替换为AI生成内容
            const placeDiv = document.createElement('div');
            placeDiv.className = 'placeholder-video';
            placeDiv.innerHTML = `
                <span style="font-size: 2.5rem;">🎬✨</span>
                <strong>AI短视频 · 即将上线</strong>
                <p style="font-size: 0.8rem; max-width: 280px;">可使用可灵/Runway将共建照片转为会动的记忆~<br>
                <span style="background: #fff3b0; display: inline-block; margin-top: 6px; padding: 4px 12px; border-radius:60px;">替换 videos/bench_story.mp4</span></p>
            `;
            modalMediaDiv.appendChild(placeDiv);
        }
        
        // 显示模态框
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // 防止背景滚动
    }
    
    // 给所有area绑定点击事件 (注意area坐标为图片热区)
    areas.forEach(area => {
        area.addEventListener('click', (e) => {
            e.preventDefault();
            const storyId = area.getAttribute('data-story');
            if (storyId && storiesDB[storyId]) {
                openStory(storyId);
            } else {
                // 默认备用
                openStory('flowerbed');
            }
        });
        // 增加触摸/鼠标样式
        area.style.cursor = 'pointer';
    });
    
    // 关闭弹窗
    function closeModal() {
        modal.style.display = 'none';
        document.body.style.overflow = '';
        // 清空媒体，以免残留video释放
        // 但保留后续再次打开不会出错
    }
    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            closeModal();
        }
    });
    // 按ESC关闭
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.style.display === 'flex') {
            closeModal();
        }
    });
    
    // ---------- 节气趣味扩展功能 (动态提醒，结合当前日期模拟谷雨/立夏等) ----------
    // 一个简易节气表 + 养护提醒库，展示趣味但不复杂
    const solarTerms = [
        { name: "立春", monthDay: "2/3", remind: "乍暖还寒，注意防冻，早春花卉可施薄肥。" },
        { name: "雨水", monthDay: "2/18", remind: "降雨增多，清沟排水，盆栽避免积水。" },
        { name: "惊蛰", monthDay: "3/5", remind: "春虫萌动，检查植物病虫害，松土施肥。" },
        { name: "春分", monthDay: "3/20", remind: "平衡昼夜，适合播种向日葵、波斯菊。" },
        { name: "清明", monthDay: "4/4", remind: "种瓜点豆，花后修剪，给月季追肥。" },
        { name: "谷雨", monthDay: "4/19", remind: "雨生百谷，栽植药草，增加有机覆盖。" },
        { name: "立夏", monthDay: "5/5", remind: "植物旺盛生长，勤浇水，悬挂诱虫板。" },
        { name: "小满", monthDay: "5/20", remind: "未病先防，修剪残花，促进复花。" },
        { name: "芒种", monthDay: "6/5", remind: "夏播正忙，注意遮阴保湿，防治红蜘蛛。" },
        { name: "夏至", monthDay: "6/21", remind: "日照最长，清晨或傍晚浇水，避开暴晒。" }
    ];
    
    // 获取当前近似节气 (基于月日简单比对，用于demo)
    function getCurrentSolarTerm() {
        const now = new Date();
        const month = now.getMonth() + 1;
        const day = now.getDate();
        const md = `${month}/${day}`;
        // 精确查找今日或最近节气；为了演示，找出距今天最近的节气（差值绝对值）
        let bestTerm = solarTerms[5]; // 默认谷雨
        let minDiff = 999;
        for (let term of solarTerms) {
            const [m, d] = term.monthDay.split('/').map(Number);
            const termDate = new Date(now.getFullYear(), m-1, d);
            const diff = Math.abs(termDate - now);
            if (diff < minDiff) {
                minDiff = diff;
                bestTerm = term;
            }
        }
        return bestTerm;
    }
    
    // 养护随机小提示库（增加趣味）
    const extraReminders = [
        "🌧️ 雨后蜗牛出没，可撒蛋壳粉保护幼苗。",
