<body>

<div class="garden-container">
    <div class="garden-header">
        <h1>邻里共建花园 · 故事地图</h1>
        <p>🌿 点击花圃、认养牌或长椅，探索居民与志愿者一起创造的温暖瞬间</p>
        <div class="reminder-badge">🌱 参与共建 · 我们的花园会呼吸</div>
    </div>

    <div class="map-area">
        <div class="map-wrapper">
            <!-- 使用 image map: 展示总平面图.jpg -->
            <img src="总平面图.jpg" 
                 alt="花园总平面图，可点击花圃、认养牌、长椅等区域" 
                 class="interactive-map" 
                 usemap="#gardenMap"
                 onerror="this.onerror=null; this.src='https://placehold.co/1200x800/e2e8d5/3c5e2e?text=总平面图.jpg+%E5%8D%B3%E5%B0%86%E4%B8%8A%E4%BC%A0'; this.alt='花园平面图占位';">
            
            <!-- 定义热区映射 —— 三个示例元素: 花圃区、认养牌、休闲长椅 -->
            <map name="gardenMap">
                <!-- 花圃区: 圆形区域, 坐标大致在图片左中区域 (根据常见平面图比例设定, 图片宽高自适应, 坐标按原始图片比例，因为是relative坐标，浏览器自动处理) -->
                <area shape="circle" coords="280,320,65" href="javascript:void(0);" data-story="flowerbed" alt="多彩花圃" title="点击查看花圃故事">
