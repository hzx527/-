            const randomTip = extraReminders[Math.floor(Math.random() * extraReminders.length)];
            const choice = Math.random() > 0.3 ? randomTip : term.remind;
            if (remindSpan) remindSpan.innerText = choice + (choice === term.remind ? "" : " 🌟");
